@page "/"
@using CodeSolvedTracker.Core.Models
@inject CodeSolvedTracker.Frontend.Services.ApiService Api

<div class="container mt-4">
    <h1 class="text-center mb-4">📊 Code Solved Tracker</h1>
    
    @if (dashboard == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p>Loading your coding stats...</p>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-4 mb-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <h5 class="card-title">Total Solved</h5>
                        <h2 class="display-4">@dashboard.TotalSolved</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <h5 class="card-title">Success Rate</h5>
                        <h2 class="display-4">@dashboard.SuccessRate.ToString("F1")%</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <h5 class="card-title">Categories</h5>
                        <h2 class="display-4">@dashboard.ByCategory.Count</h2>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row mt-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">📈 Problems by Category</h5>
                    </div>
                    <div class="card-body">
                        @foreach (var cat in dashboard.ByCategory)
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between">
                                    <strong>@cat.Category</strong>
                                    <span>@cat.Count problems</span>
                                </div>
                                <div class="progress">
                                    <div class="progress-bar" role="progressbar" 
                                         style="width: @(Math.Min(cat.Count, 100))%">
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">🤖 AI Skill Analysis</h5>
                    </div>
                    <div class="card-body">
                        @if (skillGap != null && !string.IsNullOrEmpty(skillGap.Category))
                        {
                            <div class="alert alert-warning">
                                <h6>⚠️ Weakest Area: <strong>@skillGap.Category</strong></h6>
                                <div class="progress mb-2">
                                    <div class="progress-bar bg-danger" role="progressbar" 
                                         style="width: @(skillGap.GapScore * 100)%">
                                        Gap: @(skillGap.GapScore.ToString("P0"))
                                    </div>
                                </div>
                                <small>@skillGap.Recommendation</small>
                            </div>
                            
                            <button class="btn btn-primary w-100" @onclick="LoadPracticePlan" disabled="@loading">
                                @if (loading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                Generate Practice Plan →
                            </button>
                        }
                        else
                        {
                            <p class="text-muted">Start solving problems to get AI recommendations!</p>
                        }
                    </div>
                </div>
            </div>
        </div>
        
        @if (practicePlan != null && practicePlan.SuggestedProblems.Any())
        {
            <div class="row mt-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0">📝 Your Personalized Practice Plan</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>🎯 Focus:</strong> @practicePlan.Focus</p>
                            <p><strong>⏱️ Estimated Time:</strong> @practicePlan.EstimatedTime</p>
                            <h6>📚 Suggested Problems:</h6>
                            <ul class="list-group">
                                @foreach (var problem in practicePlan.SuggestedProblems)
                                {
                                    <li class="list-group-item">
                                        <strong>@problem.Title</strong>
                                        <span class="badge bg-secondary ms-2">@problem.Category</span>
                                        <span class="badge bg-info ms-2">@problem.Difficulty</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        }
        
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">🕐 Recent Activity</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Problem</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var activity in dashboard.RecentActivity.Take(5))
                                    {
                                        <tr>
                                            <td>@activity.ProblemTitle</td>
                                            <td>@activity.SolvedAt.ToString("MMM dd, HH:mm")</td>
                                            <td>
                                                <span class="badge @(activity.Status == "Accepted" ? "bg-success" : "bg-danger")">
                                                    @activity.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private DashboardData? dashboard;
    private SkillGap? skillGap;
    private PracticePlan? practicePlan;
    private bool loading = false;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }
    
    private async Task LoadData()
    {
        dashboard = await Api.GetDashboardAsync();
        skillGap = await Api.GetSkillGapAsync();
        StateHasChanged();
    }
    
    private async Task LoadPracticePlan()
    {
        loading = true;
        practicePlan = await Api.GetPracticePlanAsync();
        loading = false;
        StateHasChanged();
    }
}
